{
  "name": "@ottabase/ottaorm",
  "version": "1.0.0",
  "description": "Drizzle-based ORM for Ottabase applications with D1 support - class-based models with relationships, validations, and metadata",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.mjs",
      "require": "./dist/models/index.js"
    },
    "./base": {
      "types": "./dist/base/index.d.ts",
      "import": "./dist/base/index.mjs",
      "require": "./dist/base/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/models/index.ts src/base/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/models/index.ts src/base/index.ts --format cjs,esm --dts --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "drizzle",
    "orm",
    "database",
    "d1",
    "cloudflare",
    "models",
    "relationships"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ottabase/db": "workspace:*"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": ">=4.0.0",
    "drizzle-orm": ">=0.30.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "drizzle-orm": "catalog:",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "rimraf": "catalog:",
    "eslint": "catalog:"
  }
}
