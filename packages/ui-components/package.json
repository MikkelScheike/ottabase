{
  "name": "@ottabase/ui-components",
  "version": "1.0.0",
  "description": "Shared UI components for Ottabase applications",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dark-mode-toggle": {
      "types": "./dist/dark-mode-toggle.d.ts",
      "import": "./dist/dark-mode-toggle.mjs",
      "require": "./dist/dark-mode-toggle.js"
    },
    "./logo": {
      "types": "./dist/logo.d.ts",
      "import": "./dist/logo.mjs",
      "require": "./dist/logo.js"
    },
    "./message-box": {
      "types": "./dist/message-box.d.ts",
      "import": "./dist/message-box.mjs",
      "require": "./dist/message-box.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/dark-mode-toggle.ts src/logo.ts src/message-box.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/dark-mode-toggle.ts src/logo.ts src/message-box.ts --format cjs,esm --dts --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "mantine",
    "next-themes",
    "tabler-icons"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mantine/core": "catalog:",
    "@ottabase/config": "workspace:*",
    "@tabler/icons-react": "catalog:",
    "next-themes": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "next": ">=14.0.0",
    "@mantine/core": "^8.3.1",
    "next-themes": "^0.4.6",
    "@tabler/icons-react": "^3.35.0"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/node": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "rimraf": "catalog:",
    "eslint": "catalog:"
  }
}
