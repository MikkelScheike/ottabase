{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@ottabase/ui-components": ["./src/index.ts"],
            "@ottabase/ui-components/*": ["./src/*"]
        },
        "rootDir": "src",
        "outDir": "dist",
        "jsx": "react-jsx",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*"],
    "exclude": ["dist", "node_modules", "**/*.test.*", "**/*.spec.*"]
}
