{
    "name": "@ottabase/ottarenderer",
    "version": "1.0.0",
    "description": "Content renderer for EditorJS and HTML content in Ottabase applications",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./styles": "./src/styles.css"
    },
    "files": [
        "dist",
        "src/styles.css",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "clean": "rimraf dist",
        "lint": "eslint src --ext .ts,.tsx",
        "type-check": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "keywords": [
        "renderer",
        "editorjs",
        "html",
        "content"
    ],
    "author": "",
    "license": "MIT",
    "peerDependencies": {
        "react": "catalog:",
        "react-dom": "catalog:"
    },
    "dependencies": {
        "@ottabase/medialibrary": "workspace:*",
        "@ottabase/ui-code-highlight": "workspace:*",
        "editorjs-blocks-react-renderer": "^1.3.0",
        "html-react-parser": "^5.1.18"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "typescript": "catalog:",
        "tsup": "catalog:",
        "rimraf": "catalog:",
        "eslint": "catalog:"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/thinkdj/ottabase.git",
        "directory": "packages/ottarenderer"
    },
    "bugs": {
        "url": "https://github.com/thinkdj/ottabase/issues"
    },
    "homepage": "https://github.com/thinkdj/ottabase/tree/main/packages/ottarenderer#readme"
}
