{
    "name": "@ottabase/ui-base",
    "version": "1.0.0",
    "description": "Base UI styles and utilities for Ottabase applications",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./styles": "./styles/index.css",
        "./styles/*": "./styles/*"
    },
    "files": [
        "dist",
        "styles",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "clean": "rimraf dist",
        "lint": "eslint src --ext .ts,.tsx",
        "type-check": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "keywords": [
        "ui",
        "styles",
        "css",
        "base"
    ],
    "author": "",
    "license": "MIT",
    "peerDependencies": {
        "react": "catalog:",
        "react-dom": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "typescript": "catalog:",
        "tsup": "catalog:",
        "rimraf": "catalog:",
        "eslint": "catalog:"
    }
}
