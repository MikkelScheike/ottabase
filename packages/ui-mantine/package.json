{
    "name": "@ottabase/ui-mantine",
    "version": "1.0.0",
    "description": "Mantine UI components and providers for Ottabase applications",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./provider": {
            "types": "./dist/provider.d.ts",
            "import": "./dist/provider.mjs",
            "require": "./dist/provider.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/provider.ts src/themeConfig.ts --format cjs,esm --dts --clean --treeshake",
        "dev": "tsup src/index.ts src/provider.ts src/themeConfig.ts --format cjs,esm --dts --watch --treeshake",
        "clean": "rimraf dist",
        "lint": "eslint src --ext .ts,.tsx",
        "type-check": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "keywords": [
        "react",
        "ui",
        "components",
        "providers",
        "mantine"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {},
    "peerDependencies": {
        "react": "catalog:",
        "react-dom": "catalog:",
        "@mantine/carousel": "catalog:",
        "@mantine/core": "catalog:",
        "@mantine/hooks": "catalog:",
        "@mantine/modals": "catalog:",
        "@mantine/notifications": "catalog:"
    },
    "devDependencies": {
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "@types/node": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "typescript": "catalog:",
        "tsup": "catalog:",
        "rimraf": "catalog:",
        "eslint": "catalog:"
    }
}
