{
  "name": "@ottabase/auth",
  "version": "1.0.0",
  "description": "Authentication packages for Ottabase applications",
  "exports": {
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.esm.js",
      "require": "./dist/next/index.js"
    },
    "./next/config": {
      "types": "./dist/next/config.d.ts",
      "import": "./dist/next/config.esm.js",
      "require": "./dist/next/config.js"
    },
    "./next/providers": {
      "types": "./dist/next/providers.d.ts",
      "import": "./dist/next/providers.esm.js",
      "require": "./dist/next/providers.js"
    },
    "./next/hooks": {
      "types": "./dist/next/hooks.d.ts",
      "import": "./dist/next/hooks.esm.js",
      "require": "./dist/next/hooks.js"
    },
    "./next/types": {
      "types": "./dist/next/types.d.ts",
      "import": "./dist/next/types.esm.js",
      "require": "./dist/next/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup next/index.ts next/config.ts next/providers.tsx next/hooks.ts next/types.ts --format cjs,esm --dts --clean --out-dir dist/next",
    "dev": "tsup next/index.ts next/config.ts next/providers.tsx next/hooks.ts next/types.ts --format cjs,esm --dts --watch --out-dir dist/next",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "authentication",
    "auth",
    "nextauth",
    "prisma",
    "nextjs",
    "react",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "next-auth": "catalog:",
    "@auth/prisma-adapter": "catalog:",
    "@ottabase/db": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "next": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/node": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "next": "catalog:",
    "next-auth": "catalog:",
    "@auth/prisma-adapter": "catalog:",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "rimraf": "catalog:",
    "eslint": "catalog:"
  }
}
