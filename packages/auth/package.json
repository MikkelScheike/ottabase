{
  "name": "@ottabase/auth",
  "version": "1.0.0",
  "description": "Authentication package for Ottabase with Auth.js (NextAuth.js) support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "import": "./dist/adapter.mjs",
      "require": "./dist/adapter.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.mjs",
      "require": "./dist/config.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.mjs",
      "require": "./dist/providers.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.mjs",
      "require": "./dist/session.js"
    },
    "./adapters/drizzle": {
      "types": "./dist/adapters/drizzle-adapter.d.ts",
      "import": "./dist/adapters/drizzle-adapter.mjs",
      "require": "./dist/adapters/drizzle-adapter.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.mjs",
      "require": "./dist/components/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "auth",
    "authjs",
    "nextauth",
    "drizzle",
    "cloudflare-d1"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@auth/core": ">=0.34.0",
    "@ottabase/cf": "workspace:*",
    "@ottabase/db": "workspace:*",
    "drizzle-orm": ">=0.30.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@auth/core": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    }
  },
  "dependencies": {
    "@ottabase/cf": "workspace:*",
    "@ottabase/ui-shadcn": "workspace:*",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@ottabase/db": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "rimraf": "catalog:",
    "eslint": "catalog:"
  }
}