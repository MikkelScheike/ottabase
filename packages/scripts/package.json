{
  "name": "@ottabase/scripts",
  "version": "1.0.0",
  "description": "Utility scripts for Ottabase monorepo",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./prisma": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "db-prisma-schema-concatenate": "bin/db-prisma-schema-concatenate.cjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli/db-prisma-schema-concatenate.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/cli/db-prisma-schema-concatenate.ts --format cjs,esm --dts --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "scripts",
    "prisma",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ottabase/db": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "rimraf": "catalog:",
    "eslint": "catalog:"
  }
}
