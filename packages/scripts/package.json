{
    "name": "@ottabase/scripts",
    "version": "1.0.0",
    "description": "Utility scripts for Ottabase monorepo - schema generation, migrations, and CLI tools",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./schema": null,
        "./migrations": null
    },
    "bin": {
        "cloudflare-login": "bin/cloudflare-login.cjs",
        "cloudflare-setup": "bin/cloudflare-setup.cjs",
        "cloudflare-validate": "bin/cloudflare-validate.cjs",
        "clean-cache": "bin/clean-cache.cjs",
        "clean-reset": "bin/clean-reset.mjs",
        "clean-db": "bin/clean-db.mjs",
        "clean-kv": "bin/clean-kv.mjs"
    },
    "files": [
        "dist",
        "bin",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/cli/cloudflare-setup.ts src/cli/cloudflare-validate.ts src/cli/cloudflare-login.ts src/cli/clean-cache.ts --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts src/cli/cloudflare-setup.ts src/cli/cloudflare-validate.ts src/cli/cloudflare-login.ts src/cli/clean-cache.ts --format cjs,esm --dts --watch",
        "clean": "rimraf dist",
        "clean-cache": "node bin/clean-cache.cjs",
        "clean-reset": "node bin/clean-reset.mjs",
        "clean-db": "node bin/clean-db.mjs",
        "clean-kv": "node bin/clean-kv.mjs",
        "cloudflare-login": "node bin/cloudflare-login.cjs",
        "cloudflare-setup": "node bin/cloudflare-setup.cjs",
        "cloudflare-validate": "node bin/cloudflare-validate.cjs",
        "lint": "eslint src --ext .ts",
        "type-check": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "keywords": [
        "scripts",
        "cloudflare-d1",
        "monorepo"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@inquirer/checkbox": "^5.0.7",
        "@ottabase/db": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "eslint": "catalog:",
        "rimraf": "catalog:",
        "ts-node": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:"
    }
}
