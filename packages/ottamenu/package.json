{
    "name": "@ottabase/ottamenu",
    "version": "1.0.0",
    "description": "Menu management for Ottabase – define and render menus (sidebar, flyout, etc.)",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./persistence": {
            "types": "./dist/persistence/index.d.ts",
            "import": "./dist/persistence/index.mjs",
            "require": "./dist/persistence/index.js"
        },
        "./handlers": {
            "types": "./dist/handlers/index.d.ts",
            "import": "./dist/handlers/index.mjs",
            "require": "./dist/handlers/index.js"
        },
        "./render": {
            "types": "./dist/render/index.d.ts",
            "import": "./dist/render/index.mjs",
            "require": "./dist/render/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/persistence/index.ts src/handlers/index.ts src/render/index.tsx --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts src/persistence/index.ts src/handlers/index.ts src/render/index.tsx --format cjs,esm --dts --watch",
        "clean": "rimraf dist",
        "test": "vitest run",
        "lint": "eslint src --ext .ts,.tsx",
        "type-check": "tsc --noEmit"
    },
    "keywords": [
        "menu",
        "navigation",
        "sidebar",
        "layout"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@ottabase/ottaorm": "workspace:*",
        "@ottabase/utils": "workspace:*"
    },
    "peerDependencies": {
        "@tanstack/react-router": "catalog:",
        "drizzle-orm": "catalog:",
        "react": "catalog:"
    },
    "devDependencies": {
        "@types/react": "catalog:",
        "drizzle-orm": "catalog:",
        "react": "catalog:",
        "rimraf": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:"
    }
}
