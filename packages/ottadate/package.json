{
    "name": "@ottabase/ottadate",
    "version": "1.0.0",
    "description": "Framework-agnostic date picker with range, datetime, and fuzzy date support. Auto timezone conversion, UTC unix getter/setter.",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "sideEffects": [
        "*.css"
    ],
    "files": [
        "dist",
        "README.md"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./core": {
            "types": "./dist/core.d.ts",
            "import": "./dist/core.mjs",
            "require": "./dist/core.js"
        },
        "./fuzzy": {
            "types": "./dist/fuzzy.d.ts",
            "import": "./dist/fuzzy.mjs",
            "require": "./dist/fuzzy.js"
        },
        "./styles.css": "./dist/styles.css"
    },
    "scripts": {
        "build": "tsup && node scripts/copy-css.js",
        "dev": "tsup --watch",
        "clean": "rimraf dist",
        "lint": "eslint src --ext .ts",
        "type-check": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "dependencies": {
        "date-fns": "catalog:",
        "date-fns-tz": "catalog:"
    },
    "devDependencies": {
        "typescript": "catalog:",
        "tsup": "catalog:",
        "rimraf": "catalog:",
        "eslint": "catalog:",
        "vitest": "catalog:"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/thinkdj/ottabase.git",
        "directory": "packages/ottadate"
    },
    "bugs": {
        "url": "https://github.com/thinkdj/ottabase/issues"
    },
    "homepage": "https://github.com/thinkdj/ottabase/tree/main/packages/ottadate#readme"
}
