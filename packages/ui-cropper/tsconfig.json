{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["dom", "dom.iterable", "ES2020"],
        "noEmit": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "baseUrl": ".",
        "paths": { "@/*": ["./src/*"] }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
