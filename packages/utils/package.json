{
  "name": "@ottabase/utils",
  "version": "0.1.0",
  "description": "Set of common utility functions for file operations, string manipulation, currency formatting, email parsing, JSON handling, git operations, browser detection, and more.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./file": {
      "types": "./dist/file.d.ts",
      "import": "./dist/file.esm.js",
      "require": "./dist/file.js"
    },
    "./string": {
      "types": "./dist/string.d.ts",
      "import": "./dist/string.esm.js",
      "require": "./dist/string.js"
    },
    "./url": {
      "types": "./dist/url.d.ts",
      "import": "./dist/url.esm.js",
      "require": "./dist/url.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.esm.js",
      "require": "./dist/env.js"
    },
    "./currency": {
      "types": "./dist/currency.d.ts",
      "import": "./dist/currency.esm.js",
      "require": "./dist/currency.js"
    },
    "./email": {
      "types": "./dist/email.d.ts",
      "import": "./dist/email.esm.js",
      "require": "./dist/email.js"
    },
    "./email-gmail": {
      "types": "./dist/email-gmail.d.ts",
      "import": "./dist/email-gmail.esm.js",
      "require": "./dist/email-gmail.js"
    },
    "./json": {
      "types": "./dist/json.d.ts",
      "import": "./dist/json.esm.js",
      "require": "./dist/json.js"
    },
    "./user": {
      "types": "./dist/user.d.ts",
      "import": "./dist/user.esm.js",
      "require": "./dist/user.js"
    },
    "./git": {
      "types": "./dist/git.d.ts",
      "import": "./dist/git.esm.js",
      "require": "./dist/git.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.esm.js",
      "require": "./dist/browser.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/file.ts src/string.ts src/url.ts src/env.ts src/currency.ts src/email.ts src/email-gmail.ts src/json.ts src/user.ts src/git.ts src/browser.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/file.ts src/string.ts src/url.ts src/env.ts src/currency.ts src/email.ts src/email-gmail.ts src/json.ts src/user.ts src/git.ts src/browser.ts --format cjs,esm --dts --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "utilities",
    "file",
    "string",
    "url",
    "env",
    "currency",
    "email",
    "json",
    "user",
    "git",
    "browser",
    "tree-shakeable",
    "typescript",
    "ottabase"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
