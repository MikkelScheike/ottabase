{
  "name": "@ottabase/cf-realtime",
  "version": "0.1.0",
  "description": "A Pusher alternative for real-time pub/sub using Cloudflare Actors and Durable Objects",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.esm.js",
      "require": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.esm.js",
      "require": "./dist/client/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server/index.ts src/client/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/server/index.ts src/client/index.ts --format cjs,esm --dts --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "cloudflare",
    "durable-objects",
    "actors",
    "pubsub",
    "realtime",
    "websocket",
    "pusher",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/actors": "^0.0.1-beta.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250127.0",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "rimraf": "catalog:",
    "eslint": "catalog:"
  }
}
