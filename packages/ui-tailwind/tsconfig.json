{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "declaration": true,
        "outDir": "dist",
        "moduleResolution": "node",
        "isolatedModules": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true
    },
    "include": [
        "src",
        "tailwind.base.ts"
    ]
}