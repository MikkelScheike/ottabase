{
    "name": "@ottabase/brand-engine",
    "version": "1.0.0",
    "description": "Unified theming and design system engine for Ottabase – design tokens, theme resolution, CSS variable runtime, and layout system",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./persistence": {
            "types": "./dist/persistence/index.d.ts",
            "import": "./dist/persistence/index.mjs",
            "require": "./dist/persistence/index.js"
        },
        "./handlers": {
            "types": "./dist/handlers/brand-api.d.ts",
            "import": "./dist/handlers/brand-api.mjs",
            "require": "./dist/handlers/brand-api.js"
        },
        "./layouts": {
            "types": "./dist/layouts/index.d.ts",
            "import": "./dist/layouts/index.mjs",
            "require": "./dist/layouts/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/persistence/index.ts src/layouts/index.ts src/handlers/brand-api.ts src/handlers/layout-api.ts --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts src/persistence/index.ts src/layouts/index.ts src/handlers/brand-api.ts src/handlers/layout-api.ts --format cjs,esm --dts --watch",
        "clean": "rimraf dist",
        "lint": "eslint src --ext .ts,.tsx",
        "type-check": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "keywords": [
        "theme",
        "design-tokens",
        "brand",
        "css-variables",
        "layout",
        "design-system"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@ottabase/ottaorm": "workspace:*",
        "@ottabase/utils": "workspace:*"
    },
    "peerDependencies": {
        "@cloudflare/workers-types": "catalog:",
        "drizzle-orm": "catalog:"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "catalog:",
        "@types/node": "catalog:",
        "drizzle-orm": "catalog:",
        "eslint": "catalog:",
        "rimraf": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
