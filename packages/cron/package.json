{
    "name": "@ottabase/cron",
    "version": "1.0.0",
    "description": "Minimal cron handler for Cloudflare Workers scheduled events",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "type-check": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "catalog:",
        "@types/node": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "peerDependencies": {
        "@cloudflare/workers-types": "catalog:"
    },
    "peerDependenciesMeta": {
        "@cloudflare/workers-types": {
            "optional": true
        }
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/thinkdj/ottabase.git",
        "directory": "packages/cron"
    },
    "bugs": {
        "url": "https://github.com/thinkdj/ottabase/issues"
    },
    "homepage": "https://github.com/thinkdj/ottabase/tree/main/packages/cron#readme"
}
