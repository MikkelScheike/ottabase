{
    "name": "@ottabase/ottablog",
    "version": "0.0.1",
    "description": "Blog and content management system for Ottabase apps - supports blog posts, changelogs, and documentation",
    "type": "module",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./renderer": {
            "types": "./src/components/BlogRenderer.tsx",
            "default": "./src/components/BlogRenderer.tsx"
        }
    },
    "scripts": {
        "clean": "rm -rf .turbo node_modules",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "peerDependencies": {
        "drizzle-orm": "catalog:",
        "react": "catalog:",
        "@ottabase/ottaorm": "workspace:*",
        "@ottabase/ottarenderer": "workspace:*"
    },
    "dependencies": {
        "@ottabase/ottaorm": "workspace:*",
        "@ottabase/ottarenderer": "workspace:*"
    },
    "devDependencies": {
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "drizzle-orm": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "typescript": "catalog:"
    },
    "keywords": [
        "blog",
        "cms",
        "content",
        "changelog",
        "documentation",
        "ottabase",
        "cloudflare",
        "d1"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/thinkdj/ottabase.git",
        "directory": "packages/ottablog"
    },
    "bugs": {
        "url": "https://github.com/thinkdj/ottabase/issues"
    },
    "homepage": "https://github.com/thinkdj/ottabase/tree/main/packages/ottablog#readme"
}
