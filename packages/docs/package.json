{
    "name": "@ottabase/docs",
    "version": "1.0.0",
    "description": "Minimal, reusable documentation viewer for Markdown/MDX files",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./styles.css": "./src/styles.css",
        "./themes/github.css": "./src/themes/github.css",
        "./themes/notion.css": "./src/themes/notion.css"
    },
    "files": [
        "dist",
        "src/styles.css",
        "src/themes",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "clean": "rimraf dist",
        "lint": "eslint src --ext .ts,.tsx",
        "type-check": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "keywords": [
        "docs",
        "markdown",
        "mdx",
        "documentation",
        "react"
    ],
    "author": "",
    "license": "MIT",
    "peerDependencies": {
        "react": "catalog:",
        "react-dom": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "@vitejs/plugin-react": "catalog:",
        "eslint": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "rimraf": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
