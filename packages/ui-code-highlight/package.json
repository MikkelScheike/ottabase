{
    "name": "@ottabase/ui-code-highlight",
    "version": "1.0.0",
    "private": true,
    "description": "Core UI components, theming and providers",
    "author": "Ottabase",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./styles.css": "./src/styles.css"
    },
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "clean": "rimraf .turbo dist",
        "typecheck": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "dependencies": {
        "@ottabase/utils": "workspace:*",
        "highlight.js": "catalog:"
    },
    "peerDependencies": {
        "lucide-react": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:"
    },
    "devDependencies": {
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "eslint": "catalog:",
        "lucide-react": "catalog:",
        "react": "catalog:",
        "rimraf": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/thinkdj/ottabase.git",
        "directory": "packages/ui-code-highlight"
    },
    "bugs": {
        "url": "https://github.com/thinkdj/ottabase/issues"
    },
    "homepage": "https://github.com/thinkdj/ottabase/tree/main/packages/ui-code-highlight#readme"
}
