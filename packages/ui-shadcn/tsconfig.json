{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ottabase/ui-shadcn": [
        "./src/index.ts"
      ],
      "@ottabase/ui-shadcn/*": [
        "./src/*"
      ]
    },
    "outDir": "dist",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "strict": false,
    "isolatedModules": false,
    "noImplicitAny": false,
    "preserveSymlinks": true
  },
  "include": [
    "src/**/*",
    "components/**/*",
    "providers/**/*"
  ],
  "exclude": ["dist", "node_modules", "**/*.test.*", "**/*.spec.*"]
}
