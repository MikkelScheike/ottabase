{
  "name": "@ottabase/ui-shadcn",
  "version": "0.1.0",
  "description": "Shared shadcn/ui components and providers for Ottabase apps",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./providers": {
      "types": "./src/providers.ts",
      "import": "./dist/providers.mjs",
      "require": "./dist/providers.js"
    },
    "./styles.css": "./styles/shadcn.css"
  },
  "files": [
    "dist",
    "components",
    "providers",
    "styles",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/providers.ts --format cjs,esm --clean",
    "dev": "tsup src/index.ts src/providers.ts --format cjs,esm --watch",
    "clean": "rimraf dist",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'components/**/*.{ts,tsx}' 'providers/**/*.{ts,tsx}'",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "shadcn",
    "react",
    "tailwind",
    "components",
    "ui"
  ],
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-aspect-ratio": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-context-menu": "^2.2.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.4",
    "@radix-ui/react-menubar": "^1.1.4",
    "@radix-ui/react-navigation-menu": "^1.2.3",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-switch": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "^1.0.4",
    "lucide-react": "^0.468.0",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "peerDependencies": {
    "next": "catalog:",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
