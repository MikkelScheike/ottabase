{
    "name": "@ottabase/ui-datatable",
    "version": "1.0.0",
    "description": "Headless-first advanced data table built on TanStack Table v8 for ottabase",
    "sideEffects": false,
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "clean": "rimraf dist",
        "lint": "eslint src --ext .ts,.tsx",
        "type-check": "tsc --noEmit",
        "test": "vitest"
    },
    "dependencies": {
        "@tanstack/react-table": "^8.21.3",
        "clsx": "catalog:",
        "lucide-react": "catalog:"
    },
    "peerDependencies": {
        "@ottabase/ui-shadcn": "workspace:*",
        "@tanstack/react-query": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:"
    },
    "devDependencies": {
        "@ottabase/ui-shadcn": "workspace:*",
        "@tanstack/react-query": "catalog:",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.1.0",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "eslint": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "rimraf": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
