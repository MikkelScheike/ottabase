{
  "name": "@ottabase/queue",
  "version": "1.0.0",
  "description": "Minimal queue system for Cloudflare Workers - Laravel-inspired job dispatching",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./job": {
      "types": "./dist/job.d.ts",
      "import": "./dist/job.mjs",
      "require": "./dist/job.js"
    },
    "./processor": {
      "types": "./dist/processor.d.ts",
      "import": "./dist/processor.mjs",
      "require": "./dist/processor.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.mjs",
      "require": "./dist/adapters/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/job.ts src/processor.ts src/adapters/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/job.ts src/processor.ts src/adapters/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@ottabase/cf": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@cloudflare/workers-types": {
      "optional": true
    }
  }
}
