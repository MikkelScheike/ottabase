{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "target": "es5",
        "lib": [
            "dom",
            "dom.iterable",
            "es6"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@ottabase/ui-core": [
                "../../packages/ui-core/src"
            ],
            "@ottabase/ui-core/*": [
                "../../packages/ui-core/src/*"
            ],
            "@ottabase/config": [
                "../../packages/config/src"
            ],
            "@ottabase/config/*": [
                "../../packages/config/src/*"
            ],
            "@ottabase/state": [
                "../../packages/state/src"
            ],
            "@ottabase/state/*": [
                "../../packages/state/src/*"
            ],
            "@ottabase/ui-code-highlight": [
                "../../packages/ui-code-highlight/src"
            ],
            "@ottabase/ui-code-highlight/*": [
                "../../packages/ui-code-highlight/src/*"
            ],
            "@ottabase/ui-tailwind": [
                "../../packages/ui-tailwind/src"
            ],
            "@ottabase/ui-tailwind/*": [
                "../../packages/ui-tailwind/src/*"
            ],
            "@ottabase/ui-components": [
                "../../packages/ui-components/src/"
            ],
            "@ottabase/ui-components/*": [
                "../../packages/ui-components/src/*"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}