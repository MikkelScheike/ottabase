# App Meta Configuration
NEXT_PUBLIC_APP_NAME="Ottabase Template App"
NEXT_PUBLIC_APP_TITLE="Ottabase Template - Modern Next.js Starter"
NEXT_PUBLIC_APP_DESCRIPTION="A template application built with Ottabase monorepo - CDC Starter Kit equivalent"
NEXT_PUBLIC_APP_LOGO_URL="/logo.png"
NEXT_PUBLIC_APP_AUTHOR="Ottabase Team"
NEXT_PUBLIC_APP_KEYWORDS="Ottabase, Next.js Starter Kit, Tailwind, Mantine, Shadcn, Tremor, HTML, React, Next.js, TypeScript, JavaScript, Node.js, MongoDB"
NEXT_PUBLIC_APP_ROBOTS="index, follow"
NEXT_PUBLIC_APP_COPYRIGHT_TEXT="© 2020-2024 Ottabase Team"
NEXT_PUBLIC_APP_COMPANY_NAME="Ottabase"

# UI Framework Configuration
NEXT_PUBLIC_UI_FRAMEWORK="mantine"

# UI Configuration
NEXT_PUBLIC_PREVENT_FOUC="false"
NEXT_PUBLIC_PREVENT_FOUC_INSIDE_IFRAME="false"
NEXT_PUBLIC_UI_DEBOUNCE_MS="500"
NEXT_PUBLIC_UI_LAYOUT_MIN_WIDTH="320"
NEXT_PUBLIC_UI_LAYOUT_MAX_WIDTH="1280"
NEXT_PUBLIC_ENFORCE_GOOGLE_FONTS="true"

# Theme Configuration
NEXT_PUBLIC_THEME_COLOR_DEFAULT="tremorBlue"

# Storage Configuration
NEXT_PUBLIC_STORAGE_PREFIX="ottabase"

# API Configuration
NEXT_PUBLIC_SERVER_ERROR_HTTP_CODE="500"

# Feature: Spotlight
NEXT_PUBLIC_SPOTLIGHT_ENABLED="true"

# Feature: CrudHub
NEXT_PUBLIC_CRUDHUB_API_BASE_URL="/api/crudhub"
NEXT_PUBLIC_CRUDHUB_URL_BASE="crudhub"
NEXT_PUBLIC_CRUDHUB_URL_BASE_LISTING="browse"

# Feature: Pagination
NEXT_PUBLIC_PAGE_SIZE_DEFAULT="10"
NEXT_PUBLIC_PAGE_SIZE_MAX="100"

# Model Configuration
NEXT_PUBLIC_MODEL_DEFAULT_REL_KEY="defaults"

# Development
NODE_ENV="development"

# Database URL (for Prisma)
DATABASE_URL="postgresql://username:password@localhost:5432/ottabase"