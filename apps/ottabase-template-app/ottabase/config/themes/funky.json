            "background": "0 0% 100%",
            "foreground": "145 10% 20%",
            "primary": "142 70% 45%",
            "primary-foreground": "0 0% 100%",
            "secondary": "142 30% 90%",
            "secondary-foreground": "142 70% 45%",
            "muted": "142 30% 90%",
            "muted-foreground": "145 10% 40%",
            "accent": "142 30% 85%",
            "accent-foreground": "145 10% 20%",
            "destructive": "0 84% 60%",
            "destructive-foreground": "0 0% 100%",
            "border": "145 10% 80%",
            "input": "145 10% 90%",
            "ring": "142 70% 45%"
        },
        "dark": {
            "background": "145 15% 10%",
            "foreground": "142 30% 90%",
            "primary": "142 70% 55%",
            "primary-foreground": "145 15% 10%",
            "secondary": "145 15% 20%",
            "secondary-foreground": "142 70% 55%",
            "muted": "145 15% 20%",
            "muted-foreground": "142 30% 60%",
            "accent": "145 15% 25%",
            "accent-foreground": "142 30% 90%",
            "destructive": "0 62% 30%",
            "destructive-foreground": "0 0% 98%",
            "border": "145 15% 25%",
            "input": "145 15% 20%",
            "ring": "142 70% 55%"
