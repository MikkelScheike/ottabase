{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "types": [
      "node"
    ],
    "lib": [
      "dom",
      "dom.iterable",
      "es6",
      "es2017"
    ]
  },
  "include": [
    "../**/*.stories.*",
    "../**/*.story.*",
    "../src/**/*",
    "*.ts",
    "*.tsx"
  ]
}