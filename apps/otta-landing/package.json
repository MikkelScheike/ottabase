{
    "name": "@ottabase/otta-landing",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build --webpack",
        "build:worker": "node ./scripts/ensure-opennext-dirs.mjs && opennextjs-cloudflare build --skipBuild",
        "start": "next start",
        "lint": "eslint .",
        "type-check": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest --coverage",
        "preview": "pnpm build && pnpm build:worker && wrangler dev",
        "deploy": "pnpm build && pnpm build:worker && wrangler deploy",
        "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
        "wrangler": "wrangler",
        "localflare": "localflare"
    },
    "dependencies": {
        "@ottabase/brand-engine": "workspace:*",
        "@ottabase/brand-engine-react": "workspace:*",
