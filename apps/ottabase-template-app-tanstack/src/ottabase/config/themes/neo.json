{
    "name": "neo",
    "typography": {
        "heading": {
            "fontFamily": "Outfit",
            "url": "https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap"
        },
        "body": {
            "fontFamily": "Inter",
            "url": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
        },
        "handwriting": {
            "fontFamily": "Caveat",
            "url": "https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&display=swap"
        }
    },
    "radius": "1rem",
    "spacing": {
        "section": "3rem",
        "card": "2rem",
        "element": "0.75rem"
    },
    "shadows": {
        "xs": "0 1px 2px rgb(0 0 0 / 0.03)",
        "sm": "0 2px 6px rgb(0 0 0 / 0.05)",
        "md": "0 6px 12px -2px rgb(0 0 0 / 0.06)",
        "lg": "0 12px 20px -4px rgb(0 0 0 / 0.08)",
        "xl": "0 24px 36px -8px rgb(0 0 0 / 0.1)"
    },
    "motion": {
        "durationFast": "80ms",
        "durationNormal": "180ms",
        "durationSlow": "350ms",
        "easing": "cubic-bezier(0.25, 0.75, 0.1, 1)",
        "easingEnter": "cubic-bezier(0.05, 0.6, 0.2, 1)",
        "easingExit": "cubic-bezier(0.35, 0, 0.9, 0.3)"
    },
    "colors": {
