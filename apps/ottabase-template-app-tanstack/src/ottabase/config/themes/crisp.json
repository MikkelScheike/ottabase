{
    "name": "crisp",
    "typography": {
        "heading": {
            "fontFamily": "IBM Plex Serif",
            "url": "https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
        },
        "body": {
            "fontFamily": "Inter",
            "url": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
        },
        "handwriting": {
            "fontFamily": "Caveat",
            "url": "https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&display=swap"
        }
    },
    "radius": "0.125rem",
    "spacing": {
        "section": "2rem",
        "card": "1.25rem",
        "element": "0.4rem"
