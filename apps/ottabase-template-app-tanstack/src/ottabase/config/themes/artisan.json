{
    "name": "artisan",
    "typography": {
        "heading": {
            "fontFamily": "Outfit",
            "url": "https://fonts.googleapis.com/css2?family=Outfit:wght@600;700;800&display=swap"
        },
        "body": {
            "fontFamily": "Inter",
            "url": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
        },
        "handwriting": {
            "fontFamily": "Playfair Display",
            "url": "https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&display=swap"
        }
    },
    "radius": "0.5rem",
    "spacing": {
        "section": "2.5rem",
        "card": "1.5rem",
        "element": "0.75rem"
    },
    "shadows": {
        "xs": "0 1px 2px rgb(60 20 30 / 0.05)",
        "sm": "0 2px 4px rgb(60 20 30 / 0.07)",
        "md": "0 4px 10px -2px rgb(60 20 30 / 0.09)",
        "lg": "0 8px 20px -4px rgb(60 20 30 / 0.11)",
        "xl": "0 18px 34px -6px rgb(60 20 30 / 0.14)"
    },
    "motion": {
        "durationFast": "100ms",
        "durationNormal": "220ms",
        "durationSlow": "420ms",
        "easing": "cubic-bezier(0.3, 0.7, 0.1, 1)",
        "easingEnter": "cubic-bezier(0.05, 0.65, 0.15, 1)",
        "easingExit": "cubic-bezier(0.35, 0, 0.85, 0.25)"
    },
    "colors": {
