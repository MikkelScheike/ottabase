    },
    "layout": {
        "header": "topbar",
        "navigation": "drawer",
        "contentWidth": "full",
        "footer": true,
        "density": "comfy"
    },
    "cursors": {
        "default": "registry:arrow-emerald",
        "pointer": "registry:hand-emerald",
        "text": "text",
        "crosshair": "registry:crosshair"
    }
}
