{
  "name": "ottabase",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node dev.js",
    "dev:fe": "pnpm --filter @ottabase/ottabase-template-app-tanstack dev",
    "dev:be": "pnpm --filter @ottabase/ottabase-template-app-tanstack dev:worker",
    "dev:ui": "turbo dev --filter=@ottabase/ottabase-template-app-tanstack --filter=@ottabase/ui-*",
    "dev:pkg": "turbo dev --filter=@ottabase/*",
    "build": "turbo build --filter=./packages/*... --filter=@ottabase/ottabase-template-app-tanstack...",
    "build:app": "turbo build --filter=@ottabase/ottabase-template-app-tanstack...",
    "build:pkg": "turbo build --filter=./packages/*...",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "test": "turbo test",
    "format": "prettier --write .",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "cloudflare:setup": "pnpm --filter @ottabase/scripts exec cloudflare-setup",
    "cloudflare:validate": "pnpm --filter @ottabase/scripts exec cloudflare-validate"
  },
  "devDependencies": {
    "@babel/core": "catalog:",
    "@babel/preset-env": "catalog:",
    "@babel/preset-react": "catalog:",
    "@babel/preset-typescript": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-links": "catalog:",
    "@storybook/addon-styling-webpack": "catalog:",
    "@storybook/react-webpack5": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "babel-loader": "catalog:",
    "css-loader": "catalog:",
    "eslint-plugin-storybook": "catalog:",
    "next-themes": "catalog:",
    "pnpm": "10.24.0",
    "postcss-loader": "catalog:",
    "rimraf": "catalog:",
    "storybook": "catalog:",
    "style-loader": "catalog:",
    "tsup": "catalog:",
    "turbo": "^2.7.2",
    "tailwindcss-animate": "catalog:",
    "webpack": "^5.104.1"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}