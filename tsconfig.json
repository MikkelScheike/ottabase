{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "dom",
            "dom.iterable",
            "ES6"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "baseUrl": ".",
        "paths": {
            "@ottabase/ui-core": [
                "./packages/ui-core/src"
            ],
            "@ottabase/ui-core/*": [
                "./packages/ui-core/src/*"
            ],
            "@ottabase/config": [
                "./packages/config/src"
            ],
            "@ottabase/config/*": [
                "./packages/config/src/*"
            ],
            "@ottabase/state": [
                "./packages/state/src"
            ],
            "@ottabase/state/*": [
                "./packages/state/src/*"
            ],
            "@ottabase/ui-code-highlight": [
                "./packages/ui-code-highlight/src"
            ],
            "@ottabase/ui-code-highlight/*": [
                "./packages/ui-code-highlight/src/*"
            ],
            "@ottabase/ui-tailwind": [
                "./packages/ui-tailwind/src"
            ],
            "@ottabase/ui-tailwind/*": [
                "./packages/ui-tailwind/src/*"
            ]
        }
    },
    "include": [],
    "exclude": [
        "node_modules"
    ],
    "references": [
        {
            "path": "./packages/ui-core"
        },
        {
            "path": "./packages/config"
        },
        {
            "path": "./packages/state"
        },
        {
            "path": "./packages/ui-code-highlight"
        },
        {
            "path": "./packages/ui-tailwind"
        }
    ]
}